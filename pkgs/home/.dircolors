# Sand LS_COLORS — 低飽和、暗沙色系
# 使用 24bit 真彩：38;2;R;G;B
# 若某些環境不支援真彩，可改成接近的 8/16 色代碼。

# === 類型（type） ===
NORMAL 00
FILE   00
DIR    38;2;200;194;172    # 目錄：冷沙灰  (#c8c2ac)
LINK   38;2;157;146;120    # 符號連結：沙棕  (#9d9278)
EXEC   38;2;127;148;115    # 可執行：灰綠  (#7f9473)
FIFO   38;2;124;143;157    # FIFO：灰藍    (#7c8f9d)
SOCK   38;2;124;143;157    # Socket：灰藍  (#7c8f9d)
DOOR   38;2;124;143;157    # Solaris Door：灰藍
BLK    38;2;157;146;120    # 區塊裝置：沙棕
CHR    38;2;157;146;120    # 字元裝置：沙棕
ORPHAN 38;2;169;124;124    # 失效連結：冷紅  (#a97c7c)
MISSING 38;2;169;124;124
SETUID 38;2;200;194;172;48;2;58;49;41  # suid：前景冷沙灰+深沙背景
SETGID 38;2;200;194;172;48;2;58;49;41
CAPABILITY 38;2;200;194;172
STICKY 38;2;184;155;114                  # 黏著位：沙橘  (#b89b72)
OTHER_WRITABLE 38;2;184;155;114
STICKY_OTHER_WRITABLE 38;2;184;155;114

